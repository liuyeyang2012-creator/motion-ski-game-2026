{
  "name": "motion-ski",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/prepare-sites.mjs",
    "build:hosting": "tsc && vite build --base /game/ && node scripts/stage-hosting-game.mjs && npm --prefix hosting-site run build && node scripts/stage-hosting-dist.mjs",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "happy-dom": "^20.10.6",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35"
  }
}
